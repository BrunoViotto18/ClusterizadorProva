{
  "random_seed": 42,
  "dataset": {
    "kaggle_key": "vikrishnan/boston-house-prices",
    "path": ["datasets"],
    "file_name": "housing.csv",
    "delimiter": "\\s+",
    "columns": [
      {
        "name": "CRIM",
        "type": "numeric"
      },
      {
        "name": "ZN",
        "type": "numeric"
      },
      {
        "name": "INDUS",
        "type": "numeric"
      },
      {
        "name": "CHAS",
        "type": "categorical"
      },
      {
        "name": "NOX",
        "type": "numeric"
      },
      {
        "name": "RM",
        "type": "numeric"
      },
      {
        "name": "AGE",
        "type": "numeric"
      },
      {
        "name": "DIS",
        "type": "numeric"
      },
      {
        "name": "RAD",
        "type": "ordinal"
      },
      {
        "name": "TAX",
        "type": "numeric"
      },
      {
        "name": "PTRATIO",
        "type": "numeric"
      },
      {
        "name": "B",
        "type": "numeric"
      },
      {
        "name": "LSTAT",
        "type": "numeric"
      },
      {
        "name": "MEDV",
        "type": "numeric"
      }
    ]
  },
  "normalizer": {
    "path": ["models"],
